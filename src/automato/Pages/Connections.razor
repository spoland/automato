@page "/connections"

@using System.Net.Http.Json
@using automato.Domain.Connections
@using automato.Domain.Sftp

<MudTable Items="@Elements" FixedHeader="@fixed_header" Hover="true" Height="@(fixed_header ? "500px":"")">
    <HeaderContent>
        <MudTh>Name</MudTh>
        <MudTh>Type</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Name">@context.Name</MudTd>
        <MudTd DataLabel="Type">SFTP</MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[]{10, 50, 100}" />
    </PagerContent>
</MudTable>

<MudSwitch @bind-Checked="@fixed_header">Fixed Header</MudSwitch>

@code {
    bool fixed_header = true;

    private IEnumerable<Connection> Elements = new List<Connection>
    {
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Rapidseedbox", portNumber: 2222, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Ubuntu Server", portNumber: 22, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "App Server", portNumber: 22, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Web Server", portNumber: 22, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "FTP Server", portNumber: 22, default)
    };
}
