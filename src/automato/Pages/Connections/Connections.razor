@page "/connections"

@using System.Net.Http.Json
@using automato.Domain.Connections
@using automato.Domain.Sftp

@inject IDialogService DialogService

<MudGrid>
    <MudItem xs="12">
        <MudTable Items="@Elements" Dense="true" FixedHeader="@fixed_header" Hover="true" Height="@(fixed_header ? "500px":"")">
            <ColGroup>
                <col />
                <col />
                <col style="width: 150px;" />
            </ColGroup>
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Type</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Type">SFTP</MudTd>
                <MudTd Style="text-align:center">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" aria-label="edit"></MudIconButton>
                    <MudIconButton @onclick="DeleteConnection" Icon="@Icons.Material.Filled.Delete" aria-label="delete"></MudIconButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudItem>
    <MudItem xs="12" Class="d-flex flex-row-reverse gap-2">
        <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" object-right />
    </MudItem>
</MudGrid>

@code {

    bool fixed_header = true;

    private IEnumerable<Connection> Elements = new List<Connection>
    {
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Rapidseedbox", portNumber: 2222, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Ubuntu Server", portNumber: 22, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "App Server", portNumber: 22, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Web Server", portNumber: 22, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "FTP Server", portNumber: 22, default),
                new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Rapidseedbox", portNumber: 2222, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Ubuntu Server", portNumber: 22, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "App Server", portNumber: 22, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Web Server", portNumber: 22, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "FTP Server", portNumber: 22, default),
                new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Rapidseedbox", portNumber: 2222, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Ubuntu Server", portNumber: 22, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "App Server", portNumber: 22, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Web Server", portNumber: 22, default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "FTP Server", portNumber: 22, default)
    };

    private void DeleteConnection()
    {
        var parameters = new DialogParameters();
        parameters.Add("ContentText", "Do you really want to delete this connection?");
        parameters.Add("ButtonText", "Delete");
        parameters.Add("Color", Color.Error);

        var options = new DialogOptions() 
        {
            NoHeader = true,
            MaxWidth = MaxWidth.ExtraSmall
        };

        DialogService.Show<ConfirmationDialog>("Delete", parameters, options);
    }
}
