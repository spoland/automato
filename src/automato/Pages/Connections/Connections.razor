@page "/connections"

@using System.Net.Http.Json
@using automato.Domain.Connections
@using automato.Domain.Sftp

@inject IDialogService DialogService

<MudGrid>

    @foreach (var connection in ConnectionList)
    {
        <MudItem xs="3">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@connection.Name</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Default" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Secondary">Test</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    }

</MudGrid>

@code {

    bool fixed_header = true;

    private IEnumerable<Connection> ConnectionList = new List<Connection>
    {
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Rapidseedbox", portNumber: 2222, details: default, sshHostKeyFingerprint: default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Ubuntu Server", portNumber: 22, details: default, sshHostKeyFingerprint: default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "App Server", portNumber: 22, details: "Test application server.", sshHostKeyFingerprint: default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "Web Server", portNumber: 22, details: default, sshHostKeyFingerprint: default),
        new SftpConnection(id: ConnectionId.New(), hostname: "1234", username: "spoland", password: "password", name: "FTP Server", portNumber: 22, details: default, sshHostKeyFingerprint: default)
    };

    private void DeleteConnection()
    {
        var parameters = new DialogParameters();
        parameters.Add("ContentText", "Do you really want to delete this connection?");
        parameters.Add("ButtonText", "Delete");
        parameters.Add("Color", Color.Error);

        var options = new DialogOptions()
            {
                NoHeader = true,
                MaxWidth = MaxWidth.ExtraSmall
            };

        DialogService.Show<ConfirmationDialog>("Delete", parameters, options);
    }
}
